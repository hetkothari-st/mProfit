{
  "name": "portfolioos",
  "version": "0.1.0",
  "private": true,
  "description": "PortfolioOS — full-stack multi-asset portfolio management & accounting platform",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel --stream run dev",
    "dev:api": "pnpm --filter @portfolioos/api dev",
    "dev:web": "pnpm --filter @portfolioos/web dev",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "db:migrate": "pnpm --filter @portfolioos/api exec prisma migrate dev",
    "db:generate": "pnpm --filter @portfolioos/api exec prisma generate",
    "db:seed": "pnpm --filter @portfolioos/api exec prisma db seed",
    "db:studio": "pnpm --filter @portfolioos/api exec prisma studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-plugin-portfolioos": "workspace:*",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.9",
    "prettier": "^3.3.3",
    "prisma": "5.22.0",
    "typescript": "^5.6.3"
  }
}
