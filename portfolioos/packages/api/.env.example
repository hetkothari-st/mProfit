# ─── Database ─────────────────────────────────────────────
# Runtime role: NOSUPERUSER + NOBYPASSRLS so §3.6 RLS policies are enforced.
# Migration 20260421150000_phase_4_5_rls_app_role creates the role with the
# dev password below. Override in production via ALTER ROLE + secret store.
DATABASE_URL=postgresql://portfolioos_app:portfolioos_app_dev@localhost:5432/portfolioos
# Migration / shadow-DB role: keeps superuser privileges for CREATE TABLE etc.
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/portfolioos

# ─── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-secure-random-string-at-least-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# ─── Email (for alerts / password reset) ─────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your-app-password
SMTP_FROM="PortfolioOS <no-reply@portfolioos.in>"

# ─── Price data ───────────────────────────────────────────
NSE_API_KEY=
AMFI_NAV_URL=https://www.amfiindia.com/spages/NAVAll.txt

# ─── Vehicle / APIMall ────────────────────────────────────
# Sign up at https://apimall.in → activate "Vehicle RC Verification API"
# and "Challan Detail API" → copy your API key from the dashboard.
# The endpoint URLs below are best-guess defaults; override if your
# dashboard shows a different URL.
APIMALL_API_KEY=
APIMALL_RC_URL=https://api.apimall.in/v1/vehicle/rc-verification
APIMALL_CHALLAN_URL=https://api.apimall.in/v1/vehicle/challan-details
# Set to true to log raw API response bodies when field extraction fails
VAHAN_DEBUG=false

# ─── Storage ──────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# ─── App ──────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# ─── Web (Vite) ───────────────────────────────────────────
VITE_API_URL=http://localhost:3001
