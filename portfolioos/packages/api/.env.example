# ─── Database ─────────────────────────────────────────────
# Runtime role: NOSUPERUSER + NOBYPASSRLS so §3.6 RLS policies are enforced.
# Migration 20260421150000_phase_4_5_rls_app_role creates the role with the
# dev password below. Override in production via ALTER ROLE + secret store.
DATABASE_URL=postgresql://portfolioos_app:portfolioos_app_dev@localhost:5432/portfolioos
# Migration / shadow-DB role: keeps superuser privileges for CREATE TABLE etc.
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/portfolioos

# ─── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-secure-random-string-at-least-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# ─── Email (for alerts / password reset) ─────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your-app-password
SMTP_FROM="PortfolioOS <no-reply@portfolioos.in>"

# ─── Price data ───────────────────────────────────────────
NSE_API_KEY=
AMFI_NAV_URL=https://www.amfiindia.com/spages/NAVAll.txt

# ─── Storage ──────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# ─── App ──────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# ─── Web (Vite) ───────────────────────────────────────────
VITE_API_URL=http://localhost:3001

# ─── OnlyOffice DocumentServer (in-browser doc editing) ──────
# JWT_SECRET must match the value set on the documentserver container.
# Generate a strong random one for prod:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
ONLYOFFICE_JWT_SECRET=dev-onlyoffice-secret-change-me
ONLYOFFICE_JWT_ENABLED=true
ONLYOFFICE_PUBLIC_URL=http://localhost:8083
ONLYOFFICE_INTERNAL_URL=http://localhost:8083
# How OnlyOffice (in Docker) reaches the API (running on host).
# In Docker Desktop on Win/Mac, host.docker.internal resolves to the host.
API_PUBLIC_URL_FOR_ONLYOFFICE=http://host.docker.internal:3001
