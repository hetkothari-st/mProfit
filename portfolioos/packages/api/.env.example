# ─── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/portfolioos

# ─── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-secure-random-string-at-least-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# ─── Email (for alerts / password reset) ─────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your-app-password
SMTP_FROM="PortfolioOS <no-reply@portfolioos.in>"

# ─── Price data ───────────────────────────────────────────
NSE_API_KEY=
AMFI_NAV_URL=https://www.amfiindia.com/spages/NAVAll.txt

# ─── Storage ──────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# ─── App ──────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# ─── Web (Vite) ───────────────────────────────────────────
VITE_API_URL=http://localhost:3001
